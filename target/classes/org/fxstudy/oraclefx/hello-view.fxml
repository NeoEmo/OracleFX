<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.fxstudy.oraclefx.HelloController">
   <bottom>
        <HBox alignment="CENTER" spacing="10.0">
            <Button onAction="#pressAll" text="All" />
            <Button onAction="#pressMajor" text="Major" />
         <TextField fx:id="questionField" alignment="CENTER" onAction="#handleQuestion" promptText="Введите вопрос" />
         <opaqueInsets>
            <Insets />
         </opaqueInsets>
         <padding>
            <Insets bottom="1.0" />
         </padding>
         <BorderPane.margin>
             <Insets />
         </BorderPane.margin>
        </HBox>
   </bottom>
    <right>

        <VBox alignment="CENTER" prefHeight="500.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <TextArea fx:id="chat" editable="false" prefHeight="100.0" prefWidth="200.0" wrapText="true" BorderPane.alignment="CENTER" />
            <TextArea fx:id="card" editable="false" prefHeight="35.0" prefWidth="200.0" wrapText="true" BorderPane.alignment="CENTER" />
            <TextArea fx:id="prediction" editable="false" prefHeight="350.0" prefWidth="200.0" wrapText="true" BorderPane.alignment="CENTER" />
        </VBox>
    </right>
   <center>
       <VBox alignment="CENTER" prefHeight="350.0" prefWidth="250.0" BorderPane.alignment="CENTER">
      <TextArea fx:id="ascii" editable="false" prefHeight="500.0" prefWidth="250.0" />
       </VBox>
   </center>
   <left>
      <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" BorderPane.alignment="CENTER" />
   </left>
</BorderPane>
